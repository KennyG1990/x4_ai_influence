<content id="x4_ai_influence" name="AI Influence" description="LLM-driven faction representatives you can talk to. Conversations route through the Neural Link bridge to a local LLM; validated actions feed back into the live X4 world." author="Moshine" version="100" date="2026-06-24" save="0" enabled="1">
  <text language="44" name="AI Influence" description="LLM-driven faction representatives you can talk to. Conversations route through the Neural Link bridge to a local LLM; validated actions feed back into the live X4 world." author="Moshine" />
  <!-- Neural Link bridge extension: the in-game side that talks to the local bridge/LLM.
       (historical note: the Neural Link hard-dependency comment removed with ADR-009.) -->
  <!-- ADR-009 (2026-07-21): single mod — the x4_neural_link extension dependency is REMOVED; its
       remaining bridge lanes are being re-homed into this mod and are gated by BRIDGE_ENABLED in aic_uix.lua. -->
  <!-- djfhe HTTP client is required: it carries the chat round-trip to the Neural Link bridge.
       Without it the HTTP calls silently no-op. -->
  <dependency id="djfhe_http" />
  <!-- SirNukes Mod Support APIs provides the Hotkey + Lua-loader APIs the conversation/hotkey
       cues use; optional so the mod still loads (those features just won't bind) if it's absent. -->
  <dependency id="ws_2042901274" optional="true" /><!-- SirNukes Mod Support APIs (folder sn_mod_support_apis; the content id is the workshop id). NOTE: its Hotkey API only fires if the external X4 Python Pipe Server is running on the host. -->
</content>
