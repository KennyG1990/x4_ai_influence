<?xml version="1.0" encoding="utf-8"?>
<!-- W2 (#148): AIC war-industry REBUILD jobs — the DeadAir expedition shape verbatim
     (deadair_scripts/libraries/jobs.xml:311-331 + the xenon quota-0 pattern). quota galaxy=0: NOTHING spawns
     uncaused; a build_order activates slots via get_suitable_job exceedquota (md/aic_warindustry.xml).
     buildatshipyard+preferbuilding: the hull is CONSTRUCTED at a real shipyard by the game's own machinery
     (war-industry spec hard rule: no timers pretending to be construction). -->
<diff>
  <add sel="/jobs">
    <job id="aic_rebuild_argon_m" name="AIC Rebuild Argon M">
      <modifiers commandeerable="true" rebuild="true"/>
      <orders>
        <order order="Patrol" default="true">
          <param name="range" value="class.sector"/>
        </order>
      </orders>
      <category faction="argon" tags="[aic_rebuild_m]" size="ship_m"/>
      <quota galaxy="0" maxgalaxy="8"/>
      <location class="galaxy" macro="xu_ep2_universe_macro" faction="argon" relation="self" comparison="exact" matchextension="false"/>
      <environment buildatshipyard="true" preferbuilding="true"/>
      <ship>
        <select faction="argon" tags="[military]" size="ship_m"/>
        <loadout>
          <level min="0.5" max="1.0"/>
        </loadout>
        <owner exact="argon" overridenpc="true"/>
      </ship>
    </job>
