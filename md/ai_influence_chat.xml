<?xml version="1.0" encoding="utf-8"?>
<mdscript name="ai_influence_chat" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="md.xsd">
  <!-- Generated by X4 Forge (version 100) -->
  <!-- Author: Moshine -->
  <!-- Description: LLM-driven faction representatives you can talk to. Conversations route through the Neural Link bridge to a local LLM; validated actions feed back into the live X4 world. -->
  <cues>
    <cue name="Save_identity" namespace="this">
      <conditions>
        <check_any>
                                                                                                                                                                                                              <event_game_started/>
                                                                                                                                                                                                              <event_game_loaded/>
                                                                                                                                                                                                            </check_any>
      </conditions>
      <actions>
        <do_if value="not Save_identity.$save_uuid?">
          <set_value name="$save_uuid" min="100000000" max="999999999"/>
        </do_if>
      </actions>
    </cue>
    <!-- P1 (serverless memory): per-NPC conversation cards persisted IN THE SAVE (MD state), replacing the
         external SQLite store. Keyed by a stable token (name+faction+role). Lua<->MD transport: store rides a
         2-key event_ui_triggered table (safe under the param3 truncation cap); the load RESPONSE is a JSON
         STRING via raise_lua_event (tables can't cross MD->Lua). The $store table survives save/reload. -->
    <cue name="Cards" namespace="this">
      <conditions>
        <check_any>
          <event_game_started/>
          <event_game_loaded/>
        </check_any>
      </conditions>
      <actions>
        <do_if value="not Cards.$store?">
          <set_value name="Cards.$store" exact="table[]"/>
        </do_if>
      </actions>
    </cue>
    <cue name="Store_card" instantiate="true" namespace="this">
      <conditions>
        <event_ui_triggered screen="'ai_influence'" control="'store_card'"/>
      </conditions>
      <actions>
        <do_if value="event.param3? and event.param3.$token? and event.param3.$json?">
          <do_if value="not md.ai_influence_chat.Cards.$store?">
            <set_value name="md.ai_influence_chat.Cards.$store" exact="table[]"/>
          </do_if>
          <set_value name="$key" exact="'$' + event.param3.$token"/>
          <set_value name="md.ai_influence_chat.Cards.$store.{$key}" exact="event.param3.$json"/>
          <debug_text text="'AIC card stored token=' + event.param3.$token" filter="general"/>
        </do_if>
      </actions>
    </cue>
    <cue name="Load_card" instantiate="true" namespace="this">
      <conditions>
        <event_ui_triggered screen="'ai_influence'" control="'load_card'"/>
      </conditions>
      <actions>
        <set_value name="$token" exact="if event.param3? and event.param3.$token? then event.param3.$token else ''"/>
        <set_value name="$key" exact="'$' + $token"/>
        <set_value name="$json" exact="if md.ai_influence_chat.Cards.$store? and md.ai_influence_chat.Cards.$store.{$key}? then md.ai_influence_chat.Cards.$store.{$key} else ''"/>
        <raise_lua_event name="'AIChat.card_loaded'" param="$json"/>
        <debug_text text="'AIC card loaded token=' + $token" filter="general"/>
      </actions>
    </cue>
    <library name="Open_chat" purpose="run_actions">
      <params>
      <param name="faction" default="'argon'"/>
      <param name="target" default="'Faction Officer'"/>
      <!-- Optional opener: an ME-wheel suggestion's fuller line. When set, the window opens and
      auto-sends it as the player's first message. Empty = free-text (player types). -->
      <param name="initial" default="''"/>
      </params>
      <actions>
        <set_value name="$sid" exact="'game_unset'"/>
        <do_if value="md.ai_influence_chat.Save_identity.$save_uuid?">
          <set_value name="$sid" exact="'game_' + md.ai_influence_chat.Save_identity.$save_uuid"/>
        </do_if>
        <set_value name="$nskill" exact="if md.ai_influence_conversation.State.$skill? then md.ai_influence_conversation.State.$skill else 0"/>
        <set_value name="$nrole" exact="if md.ai_influence_conversation.State.$role? then md.ai_influence_conversation.State.$role else 'crew'"/>
        <!-- P3-a serverless grounding: real standing bucket + current sector + a few nearby known stations,
             all from PROVEN reads (relationto / player.sector / find_station space=player.sector). These ride
             the open param into the Lua prompt so every conversation is world-aware WITHOUT the Python bridge. -->
        <!-- Standing is computed in the conversation setup (D-A fix) from the NPC's owner-faction relation;
             read it here. $faction is a display name (may be a station), NOT a resolvable faction id. -->
        <set_value name="$standing" exact="if md.ai_influence_conversation.State.$standing? then md.ai_influence_conversation.State.$standing else 'neutral'"/>
        <set_value name="$psector" exact="if player.sector.exists and player.sector.knownname? then player.sector.knownname else 'unknown space'"/>
        <set_value name="$nearby" exact="''"/>
        <set_value name="$ni" exact="0"/>
        <find_station name="$NearbyStations" space="player.sector" multiple="true" knownto="faction.player"/>
        <do_for_each name="$st" in="$NearbyStations">
          <do_if value="$ni lt 3 and $st.knownname?">
            <set_value name="$nearby" exact="if $nearby == '' then $st.knownname else $nearby + ', ' + $st.knownname"/>
            <set_value name="$ni" operation="add"/>
          </do_if>
        </do_for_each>
        <!-- #216 aware-fleet-movements slice: live sector ship-traffic count rides the grounding
             (find_ship space/checkoperational/multiple — the aic_contracts-proven pattern) -->
        <set_value name="$traffic" exact="0"/>
        <find_ship name="$SectorShips" space="player.sector" checkoperational="true" multiple="true"/>
        <set_value name="$traffic" exact="if $SectorShips? then $SectorShips.count else 0"/>
        <!-- #217 doc-09 orders: is this NPC's ship PLAYER-owned? (grounded .owner == faction.player compare)
             Only owned captains may be given orders through conversation. -->
        <set_value name="$owned" exact="0"/>
        <do_if value="md.ai_influence_conversation.State.$current_npc? and md.ai_influence_conversation.State.$current_npc.ship? and md.ai_influence_conversation.State.$current_npc.ship.owner? and md.ai_influence_conversation.State.$current_npc.ship.owner == faction.player">
          <set_value name="$owned" exact="1"/>
        </do_if>
        <debug_text text="'AIC grounding traffic=' + $traffic + ' sector=' + $psector + ' owned=' + $owned" filter="general"/>
        <raise_lua_event name="'AIChat.open'" param="'faction_id=' + $faction + '|target_name=' + $target + '|save_id=' + $sid + '|npc_role=' + $nrole + '|npc_skill=' + $nskill + '|npc_ship=' + (if md.ai_influence_conversation.State.$current_npc? and md.ai_influence_conversation.State.$current_npc.ship? and md.ai_influence_conversation.State.$current_npc.ship.knownname? then md.ai_influence_conversation.State.$current_npc.ship.knownname else '') + '|npc_fleet=' + (if md.ai_influence_conversation.State.$current_npc? and md.ai_influence_conversation.State.$current_npc.ship? and md.ai_influence_conversation.State.$current_npc.ship.commander? and md.ai_influence_conversation.State.$current_npc.ship.commander.knownname? then md.ai_influence_conversation.State.$current_npc.ship.commander.knownname else '') + '|initial=' + $initial + '|standing=' + $standing + '|psector=' + $psector + '|nearby=' + $nearby + '|traffic=' + $traffic + '|npc_owned=' + $owned"/>
      </actions>
    </library>
    <cue name="Chat_boot" namespace="this">
      <actions>
        <set_value name="$booted" exact="1"/>
      </actions>
      <cues>
        <cue name="Poll_tick" namespace="this">
          <delay exact="1s" />
          <actions>
            <raise_lua_event name="'AIChat.poll'"/>
            <reset_cue cue="Poll_tick"/>
          </actions>
        </cue>
        <!-- #210 doc-06 NPC initiative: periodic pass; Lua picks a bonded-but-neglected NPC (or does nothing).
             First tick after a load hydrates the index card, so real outreach starts on the second tick. -->
        <cue name="Initiative_tick" namespace="this">
          <delay exact="10min" />
          <actions>
            <raise_lua_event name="'AIChat.initiative_tick'"/>
            <reset_cue cue="Initiative_tick"/>
          </actions>
        </cue>
      </cues>
    </cue>
  </cues>
</mdscript>