<?xml version="1.0" encoding="utf-8"?>
<mdscript name="ai_influence_chat" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="md.xsd">
  <!-- Generated by X4 Forge (version 100) -->
  <!-- Author: Moshine -->
  <!-- Description: LLM-driven faction representatives you can talk to. Conversations route through the Neural Link bridge to a local LLM; validated actions feed back into the live X4 world. -->
  <cues>
    <cue name="Save_identity" namespace="this">
      <conditions>
        <check_any>
                                                                                                                                                                                                              <event_game_started/>
                                                                                                                                                                                                              <event_game_loaded/>
                                                                                                                                                                                                            </check_any>
      </conditions>
      <actions>
        <do_if value="not Save_identity.$save_uuid?">
          <set_value name="$save_uuid" min="100000000" max="999999999"/>
        </do_if>
      </actions>
    </cue>
    <library name="Open_chat" purpose="run_actions">
      <params>
      <param name="faction" default="'argon'"/>
      <param name="target" default="'Faction Officer'"/>
      <!-- Optional opener: an ME-wheel suggestion's fuller line. When set, the window opens and
      auto-sends it as the player's first message. Empty = free-text (player types). -->
      <param name="initial" default="''"/>
      </params>
      <actions>
        <set_value name="$sid" exact="'game_unset'"/>
        <do_if value="md.ai_influence_chat.Save_identity.$save_uuid?">
          <set_value name="$sid" exact="'game_' + md.ai_influence_chat.Save_identity.$save_uuid"/>
        </do_if>
        <set_value name="$nskill" exact="if md.ai_influence_conversation.State.$skill? then md.ai_influence_conversation.State.$skill else 0"/>
        <set_value name="$nrole" exact="if md.ai_influence_conversation.State.$role? then md.ai_influence_conversation.State.$role else 'crew'"/>
        <raise_lua_event name="'AIChat.open'" param="'faction_id=' + $faction + '|target_name=' + $target + '|save_id=' + $sid + '|npc_role=' + $nrole + '|npc_skill=' + $nskill + '|npc_ship=' + (if md.ai_influence_conversation.State.$current_npc? and md.ai_influence_conversation.State.$current_npc.ship? and md.ai_influence_conversation.State.$current_npc.ship.knownname? then md.ai_influence_conversation.State.$current_npc.ship.knownname else '') + '|npc_fleet=' + (if md.ai_influence_conversation.State.$current_npc? and md.ai_influence_conversation.State.$current_npc.ship? and md.ai_influence_conversation.State.$current_npc.ship.commander? and md.ai_influence_conversation.State.$current_npc.ship.commander.knownname? then md.ai_influence_conversation.State.$current_npc.ship.commander.knownname else '') + '|initial=' + $initial"/>
      </actions>
    </library>
    <cue name="Chat_boot" namespace="this">
      <actions>
        <set_value name="$booted" exact="1"/>
      </actions>
      <cues>
        <cue name="Poll_tick" namespace="this">
          <delay exact="1s" />
          <actions>
            <raise_lua_event name="'AIChat.poll'"/>
            <reset_cue cue="Poll_tick"/>
          </actions>
        </cue>
      </cues>
    </cue>
  </cues>
</mdscript>