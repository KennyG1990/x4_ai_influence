<?xml version="1.0" encoding="utf-8"?>
<mdscript name="ai_influence_proving" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="md.xsd">
  <!-- Generated by X4 Forge (version 100) -->
  <!-- Author: Moshine -->
  <!-- Description: LLM-driven faction representatives you can talk to. Conversations route through the Neural Link bridge to a local LLM; validated actions feed back into the live X4 world. -->
  <cues>
    <cue name="Register_Test_Hotkey" instantiate="true" namespace="this">
      <conditions>
        <event_cue_signalled cue="md.Hotkey_API.Reloaded" />
      </conditions>
      <actions>
        <signal_cue_instantly cue="md.Hotkey_API.Register_Action" param="table[             $id          = 'ai_influence_force_war',             $name        = '[AI TEST] Force faction war',             $description = 'Proving test: set a faction pair to war (-1.0) and watch for combat. Use a throwaway save.',             $category    = 'AI Influence',             $onPress     = On_Force_War,             $contexts    = ['flying', 'walking']           ]"/>
        <signal_cue_instantly cue="md.Hotkey_API.Register_Key" param="table[$key = 'shift w', $id = 'ai_influence_force_war']"/>
      </actions>
    </cue>
    <cue name="On_Force_War" instantiate="true" namespace="this">
      <conditions>
        <event_cue_signalled cue="md.Setup.Start" />
      </conditions>
      <actions>
        <set_value name="$A" exact="faction.alliance"/>
        <set_value name="$B" exact="faction.player"/>
        <do_if value="$A and $B">
          <set_value name="$old" exact="$A.relationto.{$B}"/>
          <set_faction_relation faction="$A" otherfaction="$B" value="-1.0"/>
          <write_to_logbook category="alerts" title="'[AI TEST] WAR: ' + $A.knownname + ' vs ' + $B.knownname" text="'Forced relation to -1.0 (was ' + $old + '). Watch for ships engaging.'" faction="$A"/>
          <show_notification text="'[AI TEST] ' + $A.knownname + ' now hostile to ' + $B.knownname + ' (was ' + $old + ')'"/>
        </do_if>
      </actions>
    </cue>
  </cues>
</mdscript>