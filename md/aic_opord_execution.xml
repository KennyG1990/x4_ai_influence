<?xml version="1.0" encoding="utf-8"?>
<mdscript name="aic_opord_execution" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="md.xsd">
  <!-- OPORD execution issuer (Phase D). The Lua poller (AI_Influence.PollOpordOrders) GETs pending OPORD tasks
       from the bridge and fires AIChat-style ui events here. We find a real faction combat ship and give it our
       custom order.aic.opord.protectposition order (create_order). The lease is recorded on the bridge by the Lua
       AIChat.opord_issued handler (optimistic; the bridge's unique-lease index still prevents a SECOND op leasing
       the same ship). leasetag = the bridge task_id, which the aiscript echoes in its order-event reports so the
       bridge can resolve the lease. v1 holds the ship's OWN sector (proves the order pipeline in-game); precise
       target-sector resolution across the string<->object boundary is a documented refinement. -->
  <cues>
    <cue name="On_Assign" instantiate="true" namespace="this">
      <conditions>
        <event_ui_triggered screen="'ai_influence'" control="'opord_assign'"/>
      </conditions>
      <actions>
        <set_value name="$d" exact="event.param3"/>
        <set_value name="$fid" exact="if $d.$faction? then $d.$faction else ''"/>
        <set_value name="$task" exact="if $d.$task_id? then $d.$task_id else 0"/>
        <set_value name="$op" exact="if $d.$operation_id? then $d.$operation_id else ''"/>
        <set_value name="$stance" exact="if $d.$stance? then $d.$stance else 'defensive'"/>
        <!-- (#70 ENTER diag stripped 2026-07-02 per D — assign path stable; the failed-guard case below logs) -->
        <do_if value="$fid == '' or not faction.{$fid}?">
          <debug_text text="'AIC On_Assign REJECTED fid=' + $fid + ' (unknown faction)'" filter="general"/>
        </do_if>
        <do_if value="$fid != '' and faction.{$fid}?">
          <find_ship_by_true_owner groupname="$cands" faction="faction.{$fid}" space="player.galaxy" primarypurpose="purpose.fight" checkoperational="true" multiple="true"/>
          <do_for_each name="$s" in="$cands">
            <do_if value="(not $ship? or $ship == null) and $s.exists and $s.sector? and $s.primarypurpose == purpose.fight">
              <set_value name="$ship" exact="$s"/>
            </do_if>
          </do_for_each>
          <debug_text text="'AIC OPORD issue fid=' + $fid + ' cands=' + $cands.count + ' ship=' + (if $ship? and $ship != null then $ship.idcode else 'NONE')" filter="general"/>
          <do_if value="$ship? and $ship != null">
            <create_position name="$anchor" space="$ship.sector"/>
            <create_order object="$ship" id="'AICOpordProtect'">
              <param name="destination" value="[$ship.sector, $anchor]"/><!-- position params take [space, position] (DeadAir deadairdynamicuniverse.xml:12175) — a bare position fails $destination.{1}/{2} lookups -->
              <param name="opordradius" value="30000"/>
              <param name="aggressive" value="$stance == 'aggressive'"/>
              <param name="leasetag" value="$task"/>
            </create_order>
            <raise_lua_event name="'AIChat.opord_issued'" param="'op=' + $op + '|task=' + $task + '|faction=' + $fid + '|ship=' + $ship.idcode + '|name=' + $ship.knownname + '|sector=' + $ship.sector.knownname"/>
          </do_if>
          <do_else>
            <raise_lua_event name="'AIChat.opord_force_request'" param="'op=' + $op + '|task=' + $task + '|faction=' + $fid + '|role=patrol'"/>
          </do_else>
        </do_if>
      </actions>
    </cue>
    <!-- #217 doc-09: a conversational order from an OWNED captain (Lua-gated) -> the PROVEN create_order
         actuator. Ship = the conversation NPC's ship when valid+player-owned; else (probe path) any player
         fight ship via the #215-grounded find_ship_by_true_owner. Slice 1: patrol (AICOpordProtect anchor). -->
    <cue name="On_player_order" instantiate="true" namespace="this">
      <conditions>
        <event_ui_triggered screen="'ai_influence'" control="'player_order'"/>
      </conditions>
      <actions>
        <set_value name="$ord" exact="if event.param3? and event.param3.$order? then event.param3.$order else ''"/>
        <do_if value="$ord == 'patrol' or $ord == 'return' or $ord == 'hold' or $ord == 'attack' or $ord == 'follow' or $ord == 'deploy' or $ord == 'explore' or $ord == 'trade' or $ord == 'mine' or $ord == 'dock' or $ord == 'collect'">
          <set_value name="$pship" exact="null"/>
          <do_if value="md.ai_influence_conversation.State.$current_npc? and md.ai_influence_conversation.State.$current_npc.ship? and md.ai_influence_conversation.State.$current_npc.ship.owner? and md.ai_influence_conversation.State.$current_npc.ship.owner == faction.player">
            <set_value name="$pship" exact="md.ai_influence_conversation.State.$current_npc.ship"/>
          </do_if>
          <do_if value="not $pship? or $pship == null">
            <find_ship_by_true_owner groupname="$pcands" faction="faction.player" space="player.galaxy" primarypurpose="purpose.fight" checkoperational="true" multiple="true"/>
            <do_for_each name="$s" in="$pcands">
              <do_if value="(not $pship? or $pship == null) and $s.exists and $s.sector?">
                <set_value name="$pship" exact="$s"/>
              </do_if>
            </do_for_each>
          </do_if>
          <do_if value="$pship? and $pship != null">
            <!-- #282b: single orders supersede too - same retask semantics as order sets -->
            <cancel_all_orders object="$pship"/>
            <!-- #218 verb branches, each on a PROVEN actuator/param shape -->
            <do_if value="$ord == 'patrol' or $ord == 'hold'">
              <create_position name="$panchor" space="$pship.sector"/>
              <create_order object="$pship" id="'AICOpordProtect'">
                <param name="destination" value="[$pship.sector, $panchor]"/>
                <param name="opordradius" value="if $ord == 'hold' then 5000 else 30000"/>
                <param name="aggressive" value="false"/>
                <param name="leasetag" value="'player_order_' + $ord"/>
              </create_order>
              <show_notification text="'Order acknowledged: ' + $pship.knownname + ' ' + (if $ord == 'hold' then 'holding position in ' else 'patrolling ') + $pship.sector.knownname"/>
              <debug_text text="'AIC player_order ' + $ord + ' -> ' + $pship.idcode + ' (' + $pship.knownname + ') in ' + $pship.sector.knownname" filter="general"/>
            </do_if>
            <do_elseif value="$ord == 'trade'">
              <!-- #264: vanilla AutoTrade default behaviour (needs-in-game-verify) -->
              <create_order object="$pship" id="'TradeRoutine'">
                <param name="warebasket" value="$pship.warebasket.list"/>
                <param name="duration" value="1h"/>
              </create_order>
              <show_notification text="'Order acknowledged: ' + $pship.knownname + ' commencing automated trading'"/>
              <debug_text text="'AIC player_order TRADE -> ' + $pship.idcode" filter="general"/>
            </do_elseif>
            <do_elseif value="$ord == 'mine'">
              <!-- #264: vanilla AutoMine default behaviour (needs-in-game-verify) -->
              <create_order object="$pship" id="'MiningRoutine'">
                <param name="duration" value="1h"/>
              </create_order>
              <show_notification text="'Order acknowledged: ' + $pship.knownname + ' commencing automated mining'"/>
              <debug_text text="'AIC player_order MINE -> ' + $pship.idcode" filter="general"/>
            </do_elseif>
            <do_elseif value="$ord == 'dock'">
              <!-- #264: dock and wait at the nearest station in the captain's sector -->
              <find_station name="$DkSta" space="$pship.sector"/>
              <do_if value="$DkSta? and $DkSta != null">
                <create_order object="$pship" id="'DockAndWait'">
                  <param name="destination" value="$DkSta"/>
                </create_order>
                <show_notification text="'Order acknowledged: ' + $pship.knownname + ' docking at ' + $DkSta.knownname"/>
                <debug_text text="'AIC player_order DOCK -> ' + $pship.idcode + ' at ' + $DkSta.knownname" filter="general"/>
              </do_if>
              <do_else>
                <debug_text text="'AIC player_order dock: NO STATION in ' + $pship.sector.knownname" filter="general"/>
              </do_else>
            </do_elseif>
            <do_elseif value="$ord == 'collect'">
              <!-- #264: vanilla drop-collection behaviour (needs-in-game-verify) -->
              <create_order object="$pship" id="'CollectDropsInRadius'"/>
              <show_notification text="'Order acknowledged: ' + $pship.knownname + ' sweeping for floating cargo'"/>
              <debug_text text="'AIC player_order COLLECT -> ' + $pship.idcode" filter="general"/>
            </do_elseif>
            <do_elseif value="$ord == 'explore'">
              <!-- #263: vanilla Explore default-behaviour order. NEEDS-IN-GAME-VERIFY: the order id
                   is vanilla-standard but not corpus-proven; a bad id logs cleanly, no crash. -->
              <create_order object="$pship" id="'Explore'">
                <param name="timeout" value="30min"/>
              </create_order>
              <show_notification text="'Order acknowledged: ' + $pship.knownname + ' charting an exploration course'"/>
              <debug_text text="'AIC player_order EXPLORE -> ' + $pship.idcode" filter="general"/>
            </do_elseif>
            <do_elseif value="$ord == 'deploy'">
              <!-- #262 FLEET OPORD slice 1: the commander AND every subordinate each get their own
                   protect-position order - the battlegroup breaks from follow-formation into an
                   active sector picket. allsubordinates iteration is the DeadAir Fill pattern. -->
              <create_position name="$danchor" space="$pship.sector"/>
              <create_order object="$pship" id="'AICOpordProtect'">
                <param name="destination" value="[$pship.sector, $danchor]"/>
                <param name="opordradius" value="40000"/>
                <param name="aggressive" value="false"/>
                <param name="leasetag" value="'player_order_deploy'"/>
              </create_order>
              <set_value name="$dn" exact="0"/>
              <do_if value="$pship.allsubordinates? and $pship.allsubordinates.count gt 0">
                <do_for_each name="$dsub" in="$pship.allsubordinates">
                  <do_if value="$dsub.exists and $dsub.sector?">
                    <create_position name="$sanchor" space="$pship.sector"/>
                    <create_order object="$dsub" id="'AICOpordProtect'">
                      <param name="destination" value="[$pship.sector, $sanchor]"/>
                      <param name="opordradius" value="25000"/>
                      <param name="aggressive" value="false"/>
                      <param name="leasetag" value="'player_order_deploy_sub'"/>
                    </create_order>
                    <set_value name="$dn" operation="add"/>
                  </do_if>
                </do_for_each>
              </do_if>
              <show_notification text="'Order acknowledged: ' + $pship.knownname + ' deploying battlegroup (' + $dn + ' escorts) across ' + $pship.sector.knownname"/>
              <debug_text text="'AIC player_order DEPLOY -> ' + $pship.idcode + ' + ' + $dn + ' subordinates in ' + $pship.sector.knownname" filter="general"/>
            </do_elseif>
            <do_elseif value="$ord == 'return'">
              <!-- return-to-player = MoveGeneric to the nearest station in the PLAYER's sector (grounded:
                   destination takes an object; endintargetzone per ai_influence_contract MoveGeneric) -->
              <find_station name="$RetSta" space="player.sector"/>
              <do_if value="$RetSta? and $RetSta != null">
                <create_order object="$pship" id="'MoveGeneric'">
                  <param name="destination" value="$RetSta"/>
                  <param name="endintargetzone" value="true"/>
                </create_order>
                <show_notification text="'Order acknowledged: ' + $pship.knownname + ' returning to ' + player.sector.knownname"/>
                <debug_text text="'AIC player_order return -> ' + $pship.idcode + ' dest=' + $RetSta.knownname" filter="general"/>
              </do_if>
              <do_else>
                <debug_text text="'AIC player_order return: NO STATION in player sector'" filter="general"/>
              </do_else>
            </do_elseif>
            <do_elseif value="$ord == 'follow'">
              <!-- #219 (spike-proven 2026-07-22: Escort id + target param valid, GVS-020->BIX-033).
                   Follow the player's ship when they fly; on foot -> come to the player's area instead. -->
              <do_if value="player.occupiedship? and player.occupiedship != null">
                <create_order object="$pship" id="'Escort'">
                  <param name="target" value="player.occupiedship"/>
                </create_order>
                <show_notification text="'Order acknowledged: ' + $pship.knownname + ' forming up on ' + player.occupiedship.knownname"/>
                <debug_text text="'AIC player_order follow -> ' + $pship.idcode + ' escorting ' + player.occupiedship.idcode" filter="general"/>
              </do_if>
              <do_else>
                <find_station name="$FolSta" space="player.sector"/>
                <do_if value="$FolSta? and $FolSta != null">
                  <create_order object="$pship" id="'MoveGeneric'">
                    <param name="destination" value="$FolSta"/>
                    <param name="endintargetzone" value="true"/>
                  </create_order>
                  <show_notification text="'Order acknowledged: ' + $pship.knownname + ' heading to your position in ' + player.sector.knownname"/>
                  <debug_text text="'AIC player_order follow (on-foot fallback) -> ' + $pship.idcode + ' dest=' + $FolSta.knownname" filter="general"/>
                </do_if>
                <do_else>
                  <debug_text text="'AIC player_order follow: no target'" filter="general"/>
                </do_else>
              </do_else>
            </do_elseif>
            <do_elseif value="$ord == 'attack'">
              <!-- attack = engage the nearest Xenon ship in the captain's sector (owner filter proven;
                   xenon are design-permanent hostiles per the pulse guards). None -> guarded no-op. -->
              <find_ship name="$Foes" space="$pship.sector" owner="faction.xenon" checkoperational="true" multiple="true"/>
              <do_if value="$Foes? and $Foes.count gt 0">
                <create_order object="$pship" id="'Attack'">
                  <param name="primarytarget" value="$Foes.{1}"/>
                  <param name="pursuetargets" value="true"/>
                  <param name="allowothertargets" value="true"/>
                </create_order>
                <show_notification text="'Order acknowledged: ' + $pship.knownname + ' engaging ' + $Foes.{1}.knownname"/>
                <debug_text text="'AIC player_order attack -> ' + $pship.idcode + ' target=' + $Foes.{1}.knownname" filter="general"/>
              </do_if>
              <do_else>
                <show_notification text="$pship.knownname + ': no hostile contacts in ' + $pship.sector.knownname"/>
                <debug_text text="'AIC player_order attack: NO XENON in ' + $pship.sector.knownname" filter="general"/>
              </do_else>
            </do_elseif>
          </do_if>
          <do_else>
            <debug_text text="'AIC player_order ' + $ord + ': NO ELIGIBLE SHIP'" filter="general"/>
          </do_else>
        </do_if>
      </actions>
    </cue>
    <cue name="On_player_orders" instantiate="true" namespace="this">
      <conditions>
        <event_ui_triggered screen="'ai_influence'" control="'player_orders'"/>
      </conditions>
      <actions>
        <!-- #265 (U7): ORDER SETS - each step may name a sector (resolved by matching real station
             sectors galaxy-wide); steps append to the ship's native order QUEUE (schema-confirmed:
             create_order "adds it to an object's order queue"), so the ship executes them in
             sequence. Behavior verbs in a REMOTE sector queue a MoveGeneric there first. -->
        <set_value name="$n2" exact="if event.param3.$n? then event.param3.$n else 0"/>
        <do_if value="$n2 gt 0">
          <set_value name="$pship2" exact="null"/>
          <do_if value="md.ai_influence_conversation.State.$current_npc? and md.ai_influence_conversation.State.$current_npc.ship? and md.ai_influence_conversation.State.$current_npc.ship.owner? and md.ai_influence_conversation.State.$current_npc.ship.owner == faction.player">
            <set_value name="$pship2" exact="md.ai_influence_conversation.State.$current_npc.ship"/>
          </do_if>
          <do_if value="$pship2 != null">
            <!-- #282b: NEW orders SUPERSEDE the queue (vanilla retask pattern: cancel_all_orders
                 then create_order). Ken's live catch: the fresh budgeted patrol queued BEHIND a
                 stuck pre-#282 infinite Explore forever. A commander's new orders replace old. -->
            <cancel_all_orders object="$pship2"/>
            <debug_text text="'AIC ORDERSET superseding existing queue for ' + $pship2.knownname" filter="general"/>
            <find_station name="$AllSta" space="player.galaxy" multiple="true"/>
            <do_all exact="$n2" counter="$si">
              <set_value name="$sv" exact="event.param3.{'$v' + $si}"/>
              <set_value name="$sn" exact="if event.param3.{'$s' + $si}? then event.param3.{'$s' + $si} else ''"/>
              <set_value name="$tsec" exact="$pship2.sector"/>
              <set_value name="$remote" exact="false"/>
              <do_if value="$sn != '' and $AllSta? and $AllSta.count gt 0">
                <do_for_each name="$stx" in="$AllSta">
                  <do_if value="not $remote and $stx.sector? and $stx.sector.knownname == $sn">
                    <set_value name="$tsec" exact="$stx.sector"/>
                    <set_value name="$remote" exact="$tsec != $pship2.sector"/>
                  </do_if>
                </do_for_each>
              </do_if>
              <!-- #282: per-step END STATE - the player's stated duration (clamped 5-120 min) or a
                   per-verb default. Native order timeouts make each step FINISH so the queue
                   advances; the previous AICOpordProtect patrol/hold were infinite by design. -->
              <set_value name="$uv" exact="if event.param3.{'$u' + $si}? then event.param3.{'$u' + $si} else 0"/>
              <set_value name="$dur2" exact="if $uv gt 0 then ([[$uv, 5].max, 120].min * 60s) else 0s"/>
              <do_if value="$sv == 'patrol'">
                <create_order object="$pship2" id="'Patrol'">
                  <param name="space" value="$tsec"/>
                  <param name="timeout" value="if $dur2 gt 0s then $dur2 else 20min"/>
                </create_order>
              </do_if>
              <do_elseif value="$sv == 'hold'">
                <create_order object="$pship2" id="'Wait'">
                  <param name="timeout" value="if $dur2 gt 0s then $dur2 else 15min"/>
                </create_order>
              </do_elseif>
              <do_elseif value="$sv == 'attack'">
                <find_ship name="$Foes2" space="$tsec" owner="faction.xenon" checkoperational="true" multiple="true"/>
                <do_if value="$Foes2? and $Foes2.count gt 0">
                  <create_order object="$pship2" id="'Attack'">
                    <param name="primarytarget" value="$Foes2.{1}"/>
                    <param name="pursuetargets" value="true"/>
                    <param name="allowothertargets" value="true"/>
                  </create_order>
                </do_if>
              </do_elseif>
              <do_elseif value="$sv == 'dock'">
                <find_station name="$DkSta2" space="$tsec"/>
                <do_if value="$DkSta2? and $DkSta2 != null">
                  <create_order object="$pship2" id="'DockAndWait'">
                    <param name="destination" value="$DkSta2"/>
                  </create_order>
                </do_if>
              </do_elseif>
              <do_elseif value="$sv == 'trade' or $sv == 'mine' or $sv == 'explore' or $sv == 'collect'">
                <do_if value="$remote">
                  <find_station name="$MvSta" space="$tsec"/>
                  <do_if value="$MvSta? and $MvSta != null">
                    <create_order object="$pship2" id="'MoveGeneric'">
                      <param name="destination" value="$MvSta"/>
                      <param name="endintargetzone" value="true"/>
                    </create_order>
                  </do_if>
                </do_if>
                <do_if value="$sv == 'trade'">
                  <!-- #282 fix: 'AutoTrade' is a PHANTOM id (no such vanilla order - logged cleanly,
                       did nothing). TradeRoutine is the real engine order; warebasket is required. -->
                  <create_order object="$pship2" id="'TradeRoutine'">
                    <param name="warebasket" value="$pship2.warebasket.list"/>
                    <param name="duration" value="if $dur2 gt 0s then $dur2 else 1h"/>
                  </create_order>
                </do_if>
                <do_elseif value="$sv == 'mine'">
                  <!-- #282 fix: 'AutoMine' phantom -> MiningRoutine (warebasket defaults to the
                       ship's own minable basket per the vanilla order definition) -->
                  <create_order object="$pship2" id="'MiningRoutine'">
                    <param name="duration" value="if $dur2 gt 0s then $dur2 else 1h"/>
                  </create_order>
                </do_elseif>
                <do_elseif value="$sv == 'explore'">
                  <create_order object="$pship2" id="'Explore'">
                    <param name="timeout" value="if $dur2 gt 0s then $dur2 else 30min"/>
                  </create_order>
                </do_elseif>
                <do_elseif value="$sv == 'collect'">
                  <create_order object="$pship2" id="'CollectDropsInRadius'"/>
                </do_elseif>
              </do_elseif>
              <do_elseif value="$sv == 'follow'">
                <do_if value="player.occupiedship? and player.occupiedship != null">
                  <create_order object="$pship2" id="'Escort'">
                    <param name="target" value="player.occupiedship"/>
                  </create_order>
                </do_if>
              </do_elseif>
              <do_elseif value="$sv == 'return'">
                <find_station name="$RetSta2" space="player.sector"/>
                <do_if value="$RetSta2? and $RetSta2 != null">
                  <create_order object="$pship2" id="'MoveGeneric'">
                    <param name="destination" value="$RetSta2"/>
                    <param name="endintargetzone" value="true"/>
                  </create_order>
                </do_if>
              </do_elseif>
              <do_elseif value="$sv == 'deploy_sat' or $sv == 'deploy_beacon' or $sv == 'deploy_probe'">
                <!-- #284: conversational deployables - launched ONLY from the ship's REAL racks.
                     DeployObjectAtPosition itself caps to ammostorage; we read the category list
                     so no macro is hardcoded. For these verbs "until" = unit count (default 1). -->
                <set_value name="$dcat" exact="deployablecategory.satellite"/>
                <do_if value="$sv == 'deploy_beacon'">
                  <set_value name="$dcat" exact="deployablecategory.navbeacon"/>
                </do_if>
                <do_if value="$sv == 'deploy_probe'">
                  <set_value name="$dcat" exact="deployablecategory.resourceprobe"/>
                </do_if>
                <set_value name="$DMacs" exact="$pship2.ammostorage.{$dcat}.list"/>
                <do_if value="$DMacs? and $DMacs.count gt 0">
                  <set_value name="$dmac" exact="$DMacs.{1}"/>
                  <set_value name="$dstock" exact="$pship2.ammostorage.{$dmac}.count"/>
                  <set_value name="$damt" exact="1"/>
                  <do_if value="$uv gt 0">
                    <set_value name="$damt" exact="[[$uv, 1].max, $dstock].min"/>
                  </do_if>
                  <create_position name="$dpos2" space="$tsec"/>
                  <create_order object="$pship2" id="'DeployObjectAtPosition'">
                    <param name="destination" value="[$tsec, $dpos2]"/>
                    <param name="objectstodeploy" value="[$dmac]"/>
                    <param name="amountstodeploy" value="[$damt]"/>
                  </create_order>
                  <debug_text text="'AIC ORDERSET deployable ' + $sv + ' macro=' + $dmac + ' amount=' + $damt + ' stock=' + $dstock" filter="general"/>
                </do_if>
                <do_if value="not $DMacs? or $DMacs.count lt 1">
                  <debug_text text="'AIC ORDERSET ' + $sv + ' REFUSED - empty racks on ' + $pship2.knownname" filter="general"/>
                </do_if>
              </do_elseif>
              <do_elseif value="$sv == 'rescue'">
                <!-- #284: RescueInRange - sweeps own-faction spacesuits, completes naturally -->
                <create_position name="$rpos2" space="$tsec"/>
                <create_order object="$pship2" id="'RescueInRange'">
                  <param name="destination" value="[$tsec, $rpos2]"/>
                </create_order>
              </do_elseif>
              <do_elseif value="$sv == 'trade_update'">
                <!-- #284: ExploreUpdate - revisit known stations for fresh trade data; timeout
                     default 0s = ONE natural cycle (recon-verified end state, no budget needed) -->
                <create_order object="$pship2" id="'ExploreUpdate'">
                  <param name="targetspace" value="$tsec"/>
                </create_order>
              </do_elseif>
              <debug_text text="'AIC ORDERSET step ' + $si + '/' + $n2 + ': ' + $sv + ' in ' + $tsec.knownname + (if $remote then ' (remote)' else '') + (if $uv gt 0 then (' until=' + $uv + 'min') else ' (default budget)')" filter="general"/>
            </do_all>
            <show_notification text="'Order set acknowledged: ' + $pship2.knownname + ' - ' + $n2 + ' sequenced steps'"/>
          </do_if>
          <do_else>
            <debug_text text="'AIC ORDERSET: no eligible ship'" filter="general"/>
          </do_else>
        </do_if>
      </actions>
    </cue>
  </cues>
</mdscript>
