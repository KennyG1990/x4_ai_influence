<?xml version="1.0" encoding="utf-8"?>
<mdscript name="ai_influence_contract" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="md.xsd">
  <!-- Generated by X4 Forge (version 100) -->
  <!-- Author: Moshine -->
  <!-- Description: LLM-driven faction representatives you can talk to. Conversations route through the Neural Link bridge to a local LLM; validated actions feed back into the live X4 world. -->
  <cues>
    <library name="Request_action" purpose="run_actions">
                                                                                                          <actions>
                                                                                                            <raise_lua_event name="'ai_influence.request'" param="table[$faction='split']"/>
                                                                                                          </actions>
                                                                                                        </library>
    <cue name="On_action" instantiate="true" namespace="this">
                                                                                                          <conditions>
                                                                                                            <event_ui_triggered screen="'ai_influence'" control="'action'"/>
                                                                                                          </conditions>
                                                                                                          <actions>
                                                                                                            <set_value name="$act" exact="event.param3"/>
                                                                                                            <set_value name="$type" exact="if $act.$type? then $act.$type else 'none'"/>

                                                                                                            <!-- (1) Notification — immersion / safe fallback. -->
                                                                                                            <do_if value="$type == 'show_notification'">
                                                                                                              <show_notification text="if $act.$message? then $act.$message else 'AI Influence'"/>
                                                                                                            </do_if>

                                                                                                            <!-- (2) Relation move = war/relation. adjust_relation adds a delta; set_relation is absolute.
                                                                                                                 War/peace are NOT special verbs: you cross a relation threshold and the engine + faction
                                                                                                                 AI take over. Fire the news only on the CROSSING so we never re-declare.
                                                                                                                 NOTE: in X4 MD, <do_if>/<do_elseif>/<do_else> are CLOSED SIBLINGS, not nested. -->
                                                                                                            <do_elseif value="$type == 'adjust_relation' or $type == 'set_relation'">
                                                                                                              <set_value name="$WAR_ELIGIBLE" exact="-0.10"/>
                                                                                                              <set_value name="$PEACE_ELIGIBLE" exact="-0.01"/>
                                                                                                              <set_value name="$fidA" exact="if $act.$faction? then $act.$faction else ''"/>
                                                                                                              <set_value name="$fidB" exact="if $act.$target? then $act.$target else 'player'"/>
                                                                                                              <set_value name="$facA" exact="if faction.{$fidA}? then faction.{$fidA} else null"/>
                                                                                                              <set_value name="$facB" exact="if faction.{$fidB}? then faction.{$fidB} else faction.player"/>
                                                                                                              <do_if value="$facA and $facB and $act.$relation?">
                                                                                                                <set_value name="$oldRel" exact="$facA.relationto.{$facB}"/>
                                                                                                                <set_value name="$newRel" exact="if $type == 'set_relation' then $act.$relation else $oldRel + $act.$relation"/>
                                                                                                                <do_if value="$newRel gt 1.0"><set_value name="$newRel" exact="1.0"/></do_if>
                                                                                                                <do_elseif value="$newRel lt (-1.0)"><set_value name="$newRel" exact="-1.0"/></do_elseif>
                                                                                                                <set_faction_relation faction="$facA" otherfaction="$facB" value="$newRel"/>
                                                                                                                <!-- World-model write-back: report the relation we just changed so the bridge DB mirrors
                                                                                                                     reality + the dashboard's Influence Log shows it. (subject/object are the canon ids.) -->
                                                                                                                <set_value name="$rsid" exact="'game_unset'"/>
                                                                                                                <do_if value="md.ai_influence_chat.Save_identity.$save_uuid?">
                                                                                                                  <set_value name="$rsid" exact="'game_' + md.ai_influence_chat.Save_identity.$save_uuid"/>
                                                                                                                </do_if>
                                                                                                                <raise_lua_event name="'AIChat.relation_report'" param="'subject=' + $fidA + '|object=' + $fidB + '|relation=' + $newRel + '|save_id=' + $rsid"/>
                                                                                                                <do_if value="$oldRel gt $WAR_ELIGIBLE and $newRel le $WAR_ELIGIBLE">
                                                                                                                  <write_to_logbook category="alerts" title="'WAR: ' + $facA.knownname + ' vs ' + $facB.knownname" text="'Hostilities have begun.'" faction="$facA"/>
                                                                                                                  <show_notification text="'War: ' + $facA.knownname + ' vs ' + $facB.knownname"/>
                                                                                                                </do_if>
                                                                                                                <do_elseif value="$oldRel le $WAR_ELIGIBLE and $newRel gt $PEACE_ELIGIBLE">
                                                                                                                  <write_to_logbook category="alerts" title="'PEACE: ' + $facA.knownname + ' and ' + $facB.knownname" text="'A ceasefire has taken hold.'" faction="$facA"/>
                                                                                                                  <show_notification text="'Peace: ' + $facA.knownname + ' and ' + $facB.knownname"/>
                                                                                                                </do_elseif>
                                                                                                              </do_if>
                                                                                                            </do_elseif>

                                                                                                            <!-- (3) News — logbook-only immersion entry. -->
                                                                                                            <do_elseif value="$type == 'write_to_logbook' or $type == 'news'">
                                                                                                              <write_to_logbook category="general" title="if $act.$title? then $act.$title else 'Galactic News'" text="if $act.$message? then $act.$message else ''"/>
                                                                                                            </do_elseif>

                                                                                                            <!-- (4) ECONOMY transfer — GUARDED (Codex anti-cheat hardening): only fires for an EARNED transfer
                                                                                                                 (player-contract fulfilment / owned-budget draw, #63) that sets $act.$earned=='true'. A raw decision
                                                                                                                 dispatch (no earned marker) can NEVER mint/skim wares — it falls through to the unhandled branch. -->
                                                                                                            <do_elseif value="$type == 'economy' and $act.$earned? and $act.$earned == 'true'">
                                                                                                              <set_value name="$efid" exact="if $act.$faction? then $act.$faction else ''"/>
                                                                                                              <set_value name="$eware" exact="if $act.$ware? then $act.$ware else 'energycells'"/>
                                                                                                              <set_value name="$eamt" exact="if $act.$amount? then $act.$amount else 5000"/>
                                                                                                              <set_value name="$eop" exact="if $act.$op? then $act.$op else 'add'"/>
                                                                                                              <do_if value="faction.{$efid}? and ware.{$eware}?">
                                                                                                                <find_station_by_true_owner name="$estation" space="player.galaxy" faction="faction.{$efid}"/>
                                                                                                                <do_if value="$estation">
                                                                                                                  <do_if value="$eop == 'remove'">
                                                                                                                    <remove_wares object="$estation" ware="ware.{$eware}" exact="$eamt"/>
                                                                                                                  </do_if>
                                                                                                                  <do_else>
                                                                                                                    <add_wares object="$estation" ware="ware.{$eware}" exact="$eamt"/>
                                                                                                                  </do_else>
                                                                                                                  <debug_text text="'[AIINF] economy ' + $eop + ' ' + $eamt + ' ' + $eware + ' @ ' + $efid" filter="general"/>
                                                                                                                </do_if>
                                                                                                              </do_if>
                                                                                                            </do_elseif>

                                                                                                            <!-- (5) SPEC 3.3-B military: give the faction's OWN existing ships a REAL order (NO spawning) —
                                                                                                                 DeadAir pattern: find_ship_by_true_owner (combat) + create_order. kind=patrol -> MoveGeneric
                                                                                                                 toward the front; kind=raid -> Attack the target's station. -->
                                                                                                            <do_elseif value="$type == 'order'">
                                                                                                              <set_value name="$ofid" exact="if $act.$faction? then $act.$faction else ''"/>
                                                                                                              <set_value name="$okind" exact="if $act.$kind? then $act.$kind else 'patrol'"/>
                                                                                                              <set_value name="$otgt" exact="if $act.$target? then $act.$target else ''"/>
                                                                                                              <do_if value="faction.{$ofid}? and faction.{$otgt}?">
                                                                                                                <find_ship_by_true_owner groupname="$oships" faction="faction.{$ofid}" space="player.galaxy" checkoperational="true" masstraffic="false" multiple="true">
                                                                                                                  <match primarypurpose="purpose.fight"/>
                                                                                                                </find_ship_by_true_owner>
                                                                                                                <find_station_by_true_owner name="$ofront" space="player.galaxy" faction="faction.{$otgt}"/>
                                                                                                                <do_if value="$oships.count gt 0 and $ofront">
                                                                                                                  <set_value name="$oship" exact="$oships.{1}"/>
                                                                                                                  <do_if value="$okind == 'raid'">
                                                                                                                    <create_order object="$oship" id="'Attack'">
                                                                                                                      <param name="primarytarget" value="$ofront"/>
                                                                                                                      <param name="pursuetargets" value="true"/>
                                                                                                                      <param name="allowothertargets" value="true"/>
                                                                                                                    </create_order>
                                                                                                                  </do_if>
                                                                                                                  <do_else>
                                                                                                                    <create_order object="$oship" id="'MoveGeneric'">
                                                                                                                      <param name="destination" value="$ofront"/>
                                                                                                                      <param name="endintargetzone" value="true"/>
                                                                                                                      <param name="activepatrol" value="true"/>
                                                                                                                    </create_order>
                                                                                                                  </do_else>
                                                                                                                  <debug_text text="'[AIINF] order ' + $okind + ' ' + $ofid + ' vs ' + $otgt + ' ship=' + $oship.knownname" filter="general"/>
                                                                                                                  <!-- #66: watch this ordered ship for REAL combat -> hostile_events (event ledger). -->
                                                                                                                  <do_if value="md.ai_influence_combat.State.$Watched?">
                                                                                                                    <add_to_group groupname="md.ai_influence_combat.State.$Watched" object="$oship"/>
                                                                                                                  </do_if>
                                                                                                                </do_if>
                                                                                                              </do_if>
                                                                                                            </do_elseif>

                                                                                                            <do_else>
                                                                                                              <debug_text text="'[AIINF-TEST] unhandled action: ' + $type" filter="general"/>
                                                                                                            </do_else>
                                                                                                          </actions>
                                                                                                        </cue>
  </cues>
</mdscript>