<?xml version="1.0" encoding="utf-8"?>
<mdscript name="ai_influence_hotkey" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="md.xsd">
  <!-- Generated by X4 Forge (version 100) -->
  <!-- Author: Moshine -->
  <!-- Description: LLM-driven faction representatives you can talk to. Conversations route through the Neural Link bridge to a local LLM; validated actions feed back into the live X4 world. -->
  <cues>
    <cue name="Register_Hotkey" instantiate="true" namespace="this">
      <conditions>
        <event_cue_signalled cue="md.Hotkey_API.Reloaded" />
      </conditions>
      <actions>
        <signal_cue_instantly cue="md.Hotkey_API.Register_Action" param="table[             $id          = 'ai_influence_open_chat',             $name        = 'AI Influence: Open Chat',             $description = 'Open the AI Influence comm-link chat window.',             $category    = 'AI Influence',             $onPress     = On_Hotkey,             $contexts    = ['flying', 'walking']           ]"/>
        <signal_cue_instantly cue="md.Hotkey_API.Register_Key" param="table[$key = 'shift c', $id = 'ai_influence_open_chat']"/>
        <!-- DEBUG: force one OPORD threat (Teladi pressure on Argon in the player's current sector) so the whole
             OPORD pipeline can be proven live in-game without waiting for natural combat. -->
        <signal_cue_instantly cue="md.Hotkey_API.Register_Action" param="table[             $id          = 'ai_influence_debug_threat',             $name        = 'AI Influence: Force OPORD Threat (debug)',             $description = 'Inject one hostile event so an OPORD operation forms — for testing the command pipeline.',             $category    = 'AI Influence',             $onPress     = On_DebugThreat,             $contexts    = ['flying', 'walking']           ]"/>
        <signal_cue_instantly cue="md.Hotkey_API.Register_Key" param="table[$key = 'shift v', $id = 'ai_influence_debug_threat']"/>
        <!-- P1 serverless slice: fire ONE direct Player2 completion (bridge bypassed) and log the reply. -->
        <signal_cue_instantly cue="md.Hotkey_API.Register_Action" param="table[             $id          = 'ai_influence_direct_probe',             $name        = 'AI Influence: Direct Player2 Probe (P1)',             $description = 'Call Player2 at :4315 directly from Lua and print the reply to the logbook.',             $category    = 'AI Influence',             $onPress     = On_DirectProbe,             $contexts    = ['flying', 'walking']           ]"/>
        <signal_cue_instantly cue="md.Hotkey_API.Register_Key" param="table[$key = 'shift b', $id = 'ai_influence_direct_probe']"/>
      </actions>
    </cue>
    <cue name="On_Hotkey" instantiate="true" namespace="this">
      <conditions>
        <event_cue_signalled />
      </conditions>
      <actions>
        <raise_lua_event name="'AIChat.open'" />
      </actions>
    </cue>
    <cue name="On_LoadProbe" instantiate="true" namespace="this">
      <conditions>
        <check_any>
          <event_game_started/>
          <event_game_loaded/>
        </check_any>
      </conditions>
      <actions>
        <!-- NB: a bare delay element inside actions is not a valid action node (logs "Unknown action node"); the
             probe has always fired immediately on load (Lua is ready by then), so no delay is needed here. -->
        <raise_lua_event name="'AIChat.direct_probe'" param="''"/>
        <show_notification text="'[AI P1] Direct Player2 probe fired on load — see logbook.'"/>
      </actions>
    </cue>
    <cue name="On_DirectProbe" instantiate="true" namespace="this">
      <conditions>
        <event_cue_signalled />
      </conditions>
      <actions>
        <raise_lua_event name="'AIChat.direct_probe'" param="''"/>
        <show_notification text="'[AI P1] Direct Player2 probe fired — see logbook for the reply.'"/>
      </actions>
    </cue>
    <cue name="On_DebugThreat" instantiate="true" namespace="this">
      <conditions>
        <event_cue_signalled />
      </conditions>
      <actions>
        <set_value name="$sid" exact="if md.ai_influence_chat.Save_identity.$save_uuid? then 'game_' + md.ai_influence_chat.Save_identity.$save_uuid else 'game_unset'"/>
        <set_value name="$sec" exact="if player.sector.knownname? then player.sector.knownname else 'Debug Sector'"/>
        <raise_lua_event name="'AIChat.hostile_event'" param="'attacker=teladi|victim=argon|sector=' + $sec + '|kind=ship_destroyed|magnitude=5|order=|save_id=' + $sid"/>
        <show_notification text="'[AI TEST] Forced OPORD threat: Teladi pressure on Argon in ' + $sec"/>
      </actions>
    </cue>
  </cues>
</mdscript>