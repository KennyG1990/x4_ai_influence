<?xml version="1.0" encoding="utf-8"?>
<mdscript name="ai_influence_diplomacy" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="md.xsd">
  <!-- #221 LLM DIPLOMATIC EVENTS (Bannerlord-faithful, DLL-mined architecture): ongoing situations between
       factions where Player2 DECIDES each development (statement + relation delta) and a validator clamps it
       to a band before the REAL set_faction_relation executes. Cadence: one statement per event per 2
       game-hours, max ONE LLM call per 5-minute tick, only while events exist (zero calls otherwise). -->
  <cues>
    <cue name="DiploEvents" namespace="this">
      <conditions>
        <check_any>
          <event_game_started/>
          <event_game_loaded/>
        </check_any>
      </conditions>
      <actions>
        <do_if value="not DiploEvents.$Events?">
          <set_value name="DiploEvents.$Events" exact="table[]"/>
          <set_value name="DiploEvents.$Pairs" exact="[]"/>
        </do_if>
      </actions>
    </cue>
    <!-- open/close (signalled by the pulse's war transitions, or the test lane) -->
    <cue name="Open_event" instantiate="true" namespace="this">
      <conditions>
        <event_cue_signalled/>
      </conditions>
      <actions>
        <set_value name="$a" exact="event.param.$a"/>
        <set_value name="$b" exact="event.param.$b"/>
        <set_value name="$key" exact="'$d_' + $a + '_' + $b"/>
        <!-- MaxParticipatingKingdoms port: at most 4 concurrent diplomatic events -->
        <do_if value="not DiploEvents.$Events.{$key}? and DiploEvents.$Pairs.count lt 4">
          <set_value name="DiploEvents.$Events.{$key}" exact="table[$a = $a, $b = $b, $kind = event.param.$kind, $next = 0, $n = 0, $speaker = $a, $round = 1, $round_start_n = 0, $fail_a = 0, $fail_b = 0, $analysis_due = 0]"/>
          <append_to_list name="DiploEvents.$Pairs" exact="$key"/>
          <debug_text text="'AIC DIPLO event OPENED ' + $a + ' vs ' + $b + ' kind=' + event.param.$kind" filter="general"/>
        </do_if>
      </actions>
    </cue>
    <cue name="Close_event" instantiate="true" namespace="this">
      <conditions>
        <event_cue_signalled/>
      </conditions>
      <actions>
        <set_value name="$key" exact="'$d_' + event.param.$a + '_' + event.param.$b"/>
        <do_if value="DiploEvents.$Events.{$key}?">
          <remove_value name="DiploEvents.$Events.{$key}"/>
          <remove_from_list name="DiploEvents.$Pairs" exact="$key"/>
          <debug_text text="'AIC DIPLO event CLOSED ' + event.param.$a + ' vs ' + event.param.$b" filter="general"/>
        </do_if>
      </actions>
    </cue>
    <!-- test lane (probe rigs use it; harmless in production) -->
    <cue name="Open_from_lua" instantiate="true" namespace="this">
      <conditions>
        <event_ui_triggered screen="'ai_influence'" control="'diplo_open'"/>
      </conditions>
      <actions>
        <signal_cue_instantly cue="Open_event" param="table[$a = event.param3.$a, $b = event.param3.$b, $kind = event.param3.$kind]"/>
      </actions>
    </cue>
    <cue name="Open_test" instantiate="true" namespace="this">
      <conditions>
        <event_ui_triggered screen="'ai_influence'" control="'diplo_open_test'"/>
      </conditions>
      <actions>
        <signal_cue_instantly cue="Open_event" param="table[$a = event.param3.$a, $b = event.param3.$b, $kind = event.param3.$kind]"/>
      </actions>
    </cue>
    <cue name="Close_test" instantiate="true" namespace="this">
      <conditions>
        <event_ui_triggered screen="'ai_influence'" control="'diplo_close_test'"/>
      </conditions>
      <actions>
        <signal_cue_instantly cue="Close_event" param="table[$a = event.param3.$a, $b = event.param3.$b]"/>
      </actions>
    </cue>
    <!-- #222 DYNAMIC PAIR SELECTION (DeadAir dynamicwar port): every 30min, pick a galaxy-wide faction
         pair — FactionOne by fairness accumulator (DeadAir $FactionTable shape: selected -20 floor ~5,
         others drift +1..3 cap 30), FactionTwo by weighted roll over the top accumulated candidates scored
         by STRENGTH IMBALANCE (fight-ship ratio x sector ratio; imbalanced pairs are diplomatically
         interesting) — then OPEN an LLM-driven diplomatic event for them. DeadAir decides WHO; Player2
         decides WHAT (the #221 statement lane). Galaxy-wide by construction: get_factions_by_tag +
         find_ship_by_true_owner/find_sector are all space="player.galaxy". -->
    <library name="Select_pair">
      <actions>
        <do_if value="DiploEvents.$Pairs.count lt 4">
          <set_value name="$Excluded" exact="[faction.civilian, faction.criminal, faction.khaak, faction.player, faction.smuggler, faction.visitor, faction.xenon]"/>
          <get_factions_by_tag tag="tag.claimspace" result="$Pool"/>
          <remove_from_list name="$Pool" list="$Excluded" multiple="true"/>
          <do_all exact="$Pool.count" counter="$A" reverse="true">
            <do_if value="($Pool.{$A} == null) or ($Pool.{$A}.isactive != true)">
              <remove_value name="$Pool.{$A}"/>
            </do_if>
          </do_all>
          <do_if value="$Pool.count ge 2">
            <do_if value="not DiploEvents.$Chance?">
              <set_value name="DiploEvents.$Chance" exact="table[]"/>
            </do_if>
            <do_all exact="$Pool.count" counter="$B">
              <do_if value="not DiploEvents.$Chance.{$Pool.{$B}}?">
                <set_value name="DiploEvents.$Chance.{$Pool.{$B}}" exact="[15,16,17,18,19,20].random"/>
              </do_if>
            </do_all>
            <set_value name="$PoolFull" exact="[]"/>
            <do_all exact="$Pool.count" counter="$Z">
              <append_to_list name="$PoolFull" exact="$Pool.{$Z}"/>
            </do_all>
            <!-- FactionOne = highest accumulated chance (ties keep first) -->
            <set_value name="$One" exact="$Pool.{1}"/>
            <do_all exact="$Pool.count" counter="$C">
              <do_if value="DiploEvents.$Chance.{$Pool.{$C}} gt DiploEvents.$Chance.{$One}">
                <set_value name="$One" exact="$Pool.{$C}"/>
              </do_if>
            </do_all>
            <remove_from_list name="$Pool" exact="$One"/>
            <sort_list list="$Pool" sortbyvalue="DiploEvents.$Chance.{loop.element}" sortdescending="true"/>
            <do_if value="$Pool.count gt 3">
              <do_all exact="$Pool.count" counter="$D" reverse="true">
                <do_if value="$D gt 3">
                  <remove_value name="$Pool.{$D}"/>
                </do_if>
              </do_all>
            </do_if>
            <!-- strength = (fight ships + 1) x (sectors + 1); imbalance = max(r, 1/r) clamped [1, 2] -->
            <find_ship_by_true_owner groupname="$OneShips" space="player.galaxy" multiple="true" faction="$One" primarypurpose="purpose.fight"/>
            <find_sector groupname="$OneSectors" space="player.galaxy" multiple="true" owner="$One"/>
            <set_value name="$OneStr" exact="(($OneShips.count + 1)f) * (($OneSectors.count + 1)f)"/>
            <set_value name="$W" exact="[]"/>
            <do_all exact="$Pool.count" counter="$E">
              <find_ship_by_true_owner groupname="$CandShips" space="player.galaxy" multiple="true" faction="$Pool.{$E}" primarypurpose="purpose.fight"/>
              <find_sector groupname="$CandSectors" space="player.galaxy" multiple="true" owner="$Pool.{$E}"/>
              <set_value name="$CandStr" exact="(($CandShips.count + 1)f) * (($CandSectors.count + 1)f)"/>
              <set_value name="$Ratio" exact="$OneStr / $CandStr"/>
              <set_value name="$Imb" exact="[[if $Ratio ge 1.0 then $Ratio else (1.0 / $Ratio), 1.0].max, 2.0].min"/>
              <append_to_list name="$W" exact="DiploEvents.$Chance.{$Pool.{$E}} * $Imb"/>
            </do_all>
            <set_value name="$Two" exact="$Pool.random"/>
            <do_any>
              <set_value name="$Two" exact="$Pool.{1}" weight="if $Pool.{1}? then (1 + $W.{1}) else 0"/>
              <set_value name="$Two" exact="if $Pool.{2}? then $Pool.{2} else $Pool.{1}" weight="if $Pool.{2}? then (1 + $W.{2}) else 0"/>
              <set_value name="$Two" exact="if $Pool.{3}? then $Pool.{3} else $Pool.{1}" weight="if $Pool.{3}? then (1 + $W.{3}) else 0"/>
            </do_any>
            <!-- fairness churn (DeadAir DynamicWarUpdateChance shape) -->
            <do_all exact="$PoolFull.count" counter="$M">
              <do_if value="($PoolFull.{$M} == $One) or ($PoolFull.{$M} == $Two)">
                <set_value name="DiploEvents.$Chance.{$PoolFull.{$M}}" exact="[DiploEvents.$Chance.{$PoolFull.{$M}} - 20, ([4,5,6].random)].max"/>
              </do_if>
              <do_else>
                <set_value name="DiploEvents.$Chance.{$PoolFull.{$M}}" exact="[DiploEvents.$Chance.{$PoolFull.{$M}} + ([1,2,3].random), 30].min"/>
              </do_else>
            </do_all>
            <!-- FACTION-ID RESOLVER (the #205-proven pattern): faction objects stringify to DISPLAY
                 names, so match each against the known id list; unresolvable (DLC-only) pairs are skipped. -->
            <!-- extended with DLC/base ids; every lookup is ?-guarded so absent ids are harmless -->
            <set_value name="$KnownIds" exact="['argon', 'antigone', 'alliance', 'hatikvah', 'teladi', 'ministry', 'paranid', 'holyorder', 'split', 'freesplit', 'scaleplate', 'terran', 'pioneers', 'boron', 'buccaneers', 'riptide', 'court', 'yaki']"/>
            <set_value name="$OneId" exact="''"/>
            <set_value name="$TwoId" exact="''"/>
            <do_all exact="$KnownIds.count" counter="$K">
              <do_if value="$OneId == '' and faction.{$KnownIds.{$K}}? and faction.{$KnownIds.{$K}} == $One">
                <set_value name="$OneId" exact="$KnownIds.{$K}"/>
              </do_if>
              <do_if value="$TwoId == '' and faction.{$KnownIds.{$K}}? and faction.{$KnownIds.{$K}} == $Two">
                <set_value name="$TwoId" exact="$KnownIds.{$K}"/>
              </do_if>
            </do_all>
            <do_if value="$OneId != '' and $TwoId != ''">
              <debug_text text="'AIC DIPLO pair selected ' + $OneId + ' vs ' + $TwoId + ' (oneStr=' + $OneStr + ')'" filter="general"/>
              <signal_cue_instantly cue="Open_event" param="table[$a = $OneId, $b = $TwoId, $kind = 'dynamic']"/>
            </do_if>
            <do_else>
              <debug_text text="'AIC DIPLO pair unresolved (' + $One + ' / ' + $Two + '), skipped'" filter="general"/>
            </do_else>
          </do_if>
        </do_if>
      </actions>
    </library>
    <cue name="Pair_tick" instantiate="true" checkinterval="30min" checktime="player.age + 5min">
      <actions>
        <include_actions ref="Select_pair"/>
      </actions>
    </cue>
    <!-- test lane: immediate one-shot selection (probe rigs) -->
    <cue name="Pair_test" instantiate="true" namespace="this">
      <conditions>
        <event_ui_triggered screen="'ai_influence'" control="'diplo_pair_test'"/>
      </conditions>
      <actions>
        <include_actions ref="Select_pair"/>
      </actions>
    </cue>
    <!-- the statement tick: first DUE event gets ONE LLM statement request; interval 2 game-hours/event -->
    <cue name="Diplo_boot" namespace="this">
      <actions>
        <set_value name="$booted" exact="1"/>
      </actions>
      <cues>
        <cue name="Statement_tick" namespace="this">
          <delay exact="5min"/>
          <actions>
            <set_value name="$now" exact="(player.age / 1h)"/>
            <set_value name="$fired" exact="0"/>
            <do_all exact="DiploEvents.$Pairs.count" counter="$i">
              <set_value name="$k" exact="DiploEvents.$Pairs.{$i}"/>
              <do_if value="$fired == 0 and DiploEvents.$Events.{$k}?">
                <set_value name="$ev" exact="DiploEvents.$Events.{$k}"/>
                <!-- U1 migration: events opened before the round engine get the new fields defaulted -->
                <do_if value="not $ev.$round?">
                  <set_value name="$ev.$round" exact="1"/>
                  <set_value name="$ev.$round_start_n" exact="$ev.$n"/>
                  <set_value name="$ev.$fail_a" exact="0"/>
                  <set_value name="$ev.$fail_b" exact="0"/>
                  <set_value name="$ev.$analysis_due" exact="0"/>
                  <debug_text text="'AIC DIPLO migrated legacy event ' + $ev.$a + ' vs ' + $ev.$b + ' to round engine'" filter="general"/>
                </do_if>
                <!-- U1 analysis gate: a completed round waits for the referee, not more statements.
                     Stand-in until U3 lands: continue to round 2, conclude after round 2. -->
                <do_if value="($ev.$analysis_due? and $ev.$analysis_due gt 0) and $now ge $ev.$analysis_due and faction.{$ev.$a}? and faction.{$ev.$b}?">
                  <do_if value="$ev.$round ge 4">
                    <!-- U3 failsafe (port of null-result retry exhaustion): referee unreachable for
                         2+ rounds -> deterministic close, mirrors the old stand-in -->
                    <signal_cue_instantly cue="Close_event" param="table[$a = $ev.$a, $b = $ev.$b]"/>
                    <write_to_logbook category="diplomacy" title="'Talks Concluded'" text="'After ' + $ev.$round + ' rounds, the diplomacy between ' + faction.{$ev.$a}.knownname + ' and ' + faction.{$ev.$b}.knownname + ' has run its course.'"/>
                    <debug_text text="'AIC DIPLO U3 failsafe close ' + $ev.$a + ' vs ' + $ev.$b" filter="general"/>
                  </do_if>
                  <do_else>
                    <!-- U3: ask the LLM REFEREE (AnalyzeDiplomaticEvent port). Re-arms +6 beats so an
                         unanswered ask self-heals; the verdict lands via On_diplo_verdict. -->
                    <set_value name="$ev.$analysis_due" exact="$now + 6"/>
                    <raise_lua_event name="'AIChat.diplo_analyze'" param="'a=' + $ev.$a + '|b=' + $ev.$b + '|kind=' + $ev.$kind + '|round=' + $ev.$round + '|n=' + $ev.$n + '|rel=' + (if faction.{$ev.$a}.relationto.{faction.{$ev.$b}}? then faction.{$ev.$a}.relationto.{faction.{$ev.$b}} else 0)"/>
                    <debug_text text="'AIC DIPLO U3 referee asked ' + $ev.$a + ' vs ' + $ev.$b + ' round ' + $ev.$round" filter="general"/>
                  </do_else>
                </do_if>
                <do_if value="(not ($ev.$analysis_due? and $ev.$analysis_due gt 0)) and $now ge $ev.$next and faction.{$ev.$a}? and faction.{$ev.$b}?">
                  <!-- re-arm BEFORE the async call so a slow reply can't double-fire; apply re-randomizes -->
                  <set_value name="$ev.$next" exact="$now + 1"/>
                  <set_value name="$fired" exact="1"/>
                  <set_value name="$rel" exact="faction.{$ev.$a}.relationto.{faction.{$ev.$b}}"/>
                  <raise_lua_event name="'AIChat.diplo_statement'" param="'a=' + $ev.$a + '|b=' + $ev.$b + '|kind=' + $ev.$kind + '|n=' + $ev.$n + '|rel=' + $rel + '|speaker=' + $ev.$speaker"/>
                  <debug_text text="'AIC DIPLO statement requested speaker=' + $ev.$speaker + ' (' + $ev.$a + ' vs ' + $ev.$b + ') rel=' + $rel" filter="general"/>
                </do_if>
              </do_if>
            </do_all>
            <reset_cue cue="Statement_tick"/>
          </actions>
        </cue>
      </cues>
    </cue>
    <!-- U1 failure discipline: a failed LLM statement retries in 1 beat, max 3 attempts; at the cap the
         speaker is counted as responded (advance speaker + round math without a statement). -->
    <cue name="On_diplo_verdict" instantiate="true" namespace="this">
      <conditions>
        <event_ui_triggered screen="'ai_influence'" control="'diplo_verdict'"/>
      </conditions>
      <actions>
        <set_value name="$vd" exact="event.param3"/>
        <set_value name="$vkey" exact="'$d_' + $vd.$a + '_' + $vd.$b"/>
        <do_if value="DiploEvents.$Events.{$vkey}?">
          <set_value name="$vev" exact="DiploEvents.$Events.{$vkey}"/>
          <!-- #258: verdict DEDUP (live-observed race 2026-07-22: two tick instances asked the
               referee in the same beat) - only the FIRST verdict counts; it zeroes analysis_due,
               so any duplicate arriving after is dropped here. -->
          <do_if value="not ($vev.$analysis_due? and $vev.$analysis_due gt 0)">
            <debug_text text="'AIC DIPLO U3 duplicate verdict dropped for ' + $vd.$a + ' vs ' + $vd.$b" filter="general"/>
          </do_if>
          <do_if value="($vev.$analysis_due? and $vev.$analysis_due gt 0) and $vd.$verdict? and $vd.$verdict == 'end'">
            <signal_cue_instantly cue="Close_event" param="table[$a = $vd.$a, $b = $vd.$b]"/>
            <write_to_logbook category="diplomacy" title="'Talks Concluded'" text="if $vd.$update? then $vd.$update else 'The talks have concluded.'"/>
            <debug_text text="'AIC DIPLO U3 referee CONCLUDES ' + $vd.$a + ' vs ' + $vd.$b" filter="general"/>
          </do_if>
          <do_elseif value="$vev.$analysis_due? and $vev.$analysis_due gt 0">
            <set_value name="$vev.$round" operation="add"/>
            <set_value name="$vev.$round_start_n" exact="$vev.$n"/>
            <set_value name="$vev.$analysis_due" exact="0"/>
            <set_value name="$viv" min="1" max="2"/>
            <set_value name="$vev.$next" exact="(player.age / 1h) + $viv"/>
            <write_to_logbook category="diplomacy" title="'Talks Continue'" text="if $vd.$update? then $vd.$update else 'Negotiations continue.'"/>
            <debug_text text="'AIC DIPLO U3 referee CONTINUES ' + $vd.$a + ' vs ' + $vd.$b + ' -> round ' + $vev.$round" filter="general"/>
          </do_else>
        </do_if>
      </actions>
    </cue>
    <cue name="Stmt_failed" instantiate="true" namespace="this">
      <conditions>
        <event_ui_triggered screen="'ai_influence'" control="'diplo_stmt_failed'"/>
      </conditions>
      <actions>
        <set_value name="$fkey" exact="'$d_' + event.param3.$a + '_' + event.param3.$b"/>
        <do_if value="DiploEvents.$Events.{$fkey}?">
          <set_value name="$fev" exact="DiploEvents.$Events.{$fkey}"/>
          <set_value name="$fails" exact="if $fev.$speaker == $fev.$a then $fev.$fail_a else $fev.$fail_b"/>
          <do_if value="$fails lt 3">
            <do_if value="$fev.$speaker == $fev.$a">
              <set_value name="$fev.$fail_a" operation="add"/>
            </do_if>
            <do_else>
              <set_value name="$fev.$fail_b" operation="add"/>
            </do_else>
            <set_value name="$fev.$next" exact="(player.age / 1h) + 1"/>
            <debug_text text="'AIC DIPLO statement FAILED for ' + $fev.$speaker + ' (attempt ' + ($fails + 1) + '/3), retry scheduled'" filter="general"/>
          </do_if>
          <do_else>
            <set_value name="$fev.$n" operation="add"/>
            <do_if value="$fev.$speaker == $fev.$a">
              <set_value name="$fev.$speaker" exact="$fev.$b"/>
              <set_value name="$fev.$fail_a" exact="0"/>
            </do_if>
            <do_else>
              <set_value name="$fev.$speaker" exact="$fev.$a"/>
              <set_value name="$fev.$fail_b" exact="0"/>
            </do_else>
            <do_if value="($fev.$n - $fev.$round_start_n) ge 2">
              <set_value name="$adly2" min="1" max="2"/>
              <set_value name="$fev.$analysis_due" exact="(player.age / 1h) + $adly2"/>
            </do_if>
            <set_value name="$fev.$next" exact="(player.age / 1h) + 1"/>
            <debug_text text="'AIC DIPLO max retries; ' + event.param3.$a + ' vs ' + event.param3.$b + ' speaker counted as responded'" filter="general"/>
          </do_else>
        </do_if>
      </actions>
    </cue>
    <!-- the executor: validated LLM decision -> REAL relation change + news + ledger. The debug line
         printing old->new IS the engine proof that the LLM decided a real gamestate change. -->
    <cue name="Diplo_apply" instantiate="true" namespace="this">
      <conditions>
        <event_ui_triggered screen="'ai_influence'" control="'diplo_apply'"/>
      </conditions>
      <actions>
        <set_value name="$d" exact="event.param3"/>
        <do_if value="$d? and $d.$a? and $d.$b? and faction.{$d.$a}? and faction.{$d.$b}?">
          <set_value name="$old" exact="faction.{$d.$a}.relationto.{faction.{$d.$b}}"/>
          <set_value name="$new" exact="[[$old + $d.$delta, 1.0].min, -1.0].max"/>
          <set_faction_relation faction="faction.{$d.$a}" otherfaction="faction.{$d.$b}" value="$new"/>
          <set_faction_relation faction="faction.{$d.$b}" otherfaction="faction.{$d.$a}" value="$new"/>
          <set_value name="$ekey" exact="'$d_' + $d.$a + '_' + $d.$b"/>
          <do_if value="DiploEvents.$Events.{$ekey}?">
            <set_value name="DiploEvents.$Events.{$ekey}.$n" operation="add"/>
            <!-- U1 round bookkeeping: 2-party round completes when both spoke since round start -->
            <set_value name="$inRound" exact="DiploEvents.$Events.{$ekey}.$n - DiploEvents.$Events.{$ekey}.$round_start_n"/>
            <do_if value="$inRound ge 2">
              <set_value name="$adly" min="1" max="2"/>
              <set_value name="DiploEvents.$Events.{$ekey}.$analysis_due" exact="(player.age / 1h) + $adly"/>
              <debug_text text="'AIC DIPLO round ' + DiploEvents.$Events.{$ekey}.$round + ' COMPLETE (' + $d.$a + ' vs ' + $d.$b + '); analysis scheduled'" filter="general"/>
            </do_if>
            <!-- ContinueDiplomaticNegotiations port: the OTHER faction speaks next, after a random 1-3 beat gap -->
            <set_value name="$iv" min="1" max="3"/>
            <set_value name="DiploEvents.$Events.{$ekey}.$next" exact="(player.age / 1h) + $iv"/>
            <do_if value="DiploEvents.$Events.{$ekey}.$speaker == $d.$a">
              <set_value name="DiploEvents.$Events.{$ekey}.$speaker" exact="$d.$b"/>
            </do_if>
            <do_else>
              <set_value name="DiploEvents.$Events.{$ekey}.$speaker" exact="$d.$a"/>
            </do_else>
          </do_if>
          <do_if value="$d.$statement? and $d.$statement != ''">
            <set_value name="$srcname" exact="if $d.$speaker? and faction.{$d.$speaker}? then faction.{$d.$speaker}.knownname else 'Galactic Diplomatic Service'"/>
            <!-- #289: diplomatic statements no longer ping Messages - Logbook Diplomacy tab only -->
            <write_to_logbook category="diplomacy" title="'Diplomatic Statement'" text="$d.$statement"/>
          </do_if>
          <raise_lua_event name="'AIChat.world_event'" param="'kind=shift|a=' + faction.{$d.$a}.knownname + '|b=' + faction.{$d.$b}.knownname + '|to=' + $d.$action"/>
          <debug_text text="'AIC DIPLO LLM-DECIDED ' + $d.$a + ' vs ' + $d.$b + ' action=' + $d.$action + ' delta=' + $d.$delta + ' rel ' + $old + ' -> ' + $new" filter="general"/>
        </do_if>
      </actions>
    </cue>
  </cues>
</mdscript>
