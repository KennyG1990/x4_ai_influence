<?xml version="1.0" encoding="utf-8"?>
<mdscript name="ai_influence_worldsync" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="md.xsd">
  <!-- Generated by X4 Forge (version 100) -->
  <!-- Author: Moshine -->
  <!-- Description: LLM-driven NPCs and factions. Serverless: X4 Lua talks directly to the local Player2 runtime (:4315); validated actions feed back into the live X4 world. -->
  <cues>
    <library name="Do_sync" purpose="run_actions">
      <actions>
        <set_value name="$sid" exact="'game_unset'"/>
        <do_if value="md.ai_influence_chat.Save_identity.$save_uuid?">
          <set_value name="$sid" exact="'game_' + md.ai_influence_chat.Save_identity.$save_uuid"/>
        </do_if>
        <set_value name="$ids" exact="['argon', 'antigone', 'alliance', 'teladi', 'ministry', 'paranid', 'holyorder', 'split', 'freesplit', 'scaleplate', 'xenon', 'khaak', 'player']"/>
        <set_value name="$report" exact="''"/>
        <do_for_each name="$idA" in="$ids">
          <do_for_each name="$idB" in="$ids">
            <do_if value="$idA != $idB and faction.{$idA}? and faction.{$idB}?">
              <set_value name="$rel" exact="faction.{$idA}.relationto.{faction.{$idB}}"/>
              <set_value name="$report" exact="$report + $idA + '~' + $idB + '~' + $rel + ';'"/>
            </do_if>
          </do_for_each>
        </do_for_each>
        <raise_lua_event name="'AIChat.sync_relations'" param="'save_id=' + $sid + '||' + $report"/>
      </actions>
    </library>
    <!-- NPC CENSUS (live roster, Tier 1/2): index the COMMANDING NPC (controlentity = manager/captain) of every
         station in the player's CURRENT sector, so the roster fills WITHOUT requiring a conversation. Scoped to
         player.sector (cheap, a handful of stations) — NOT a galaxy-wide person dump. Reuses the existing
         AIChat.index_npcs -> /v1/npcs/index path verbatim. controlentity/knownname/owner.knownname are grounded
         (conversation.xml already reads owner.knownname + knownname). NOTE: this gives session visibility, not
         cross-reload identity (X4 has no stable person id — proven). -->
    <library name="Census_npcs" purpose="run_actions">
      <actions>
        <set_value name="$sid" exact="'game_unset'"/>
        <do_if value="md.ai_influence_chat.Save_identity.$save_uuid?">
          <set_value name="$sid" exact="'game_' + md.ai_influence_chat.Save_identity.$save_uuid"/>
        </do_if>
        <set_value name="$npcs" exact="''"/>
        <find_station groupname="$stations" space="player.sector" multiple="true"/>
        <do_for_each name="$st" in="$stations">
          <do_if value="$st.manager? and $st.manager.knownname? and $st.owner?">
            <set_value name="$npcs" exact="$npcs + $st.manager.knownname + '~' + $st.owner.knownname + ';'"/>
          </do_if>
        </do_for_each>
        <debug_text text="'AIINF census: stations=' + $stations.count + ' npcs=[' + $npcs + ']'" filter="general"/>
        <do_if value="$npcs != ''">
          <raise_lua_event name="'AIChat.index_npcs'" param="'save_id=' + $sid + '|player=Player|npcs=' + $npcs"/>
        </do_if>
      </actions>
    </library>
    <!-- CONTROL-POST OFFICERS (defence + engineer): the NON-default station control posts the Lua census can't
         reach (Lua FFI GetControlEntity = DEFAULT / manager only). MD-only via controlentity.{controlpost.X}
         (grounded: scriptproperties `controlentity.{$controlpost}`; live post ids manager/defence/engineer).
         Current-sector scope (cheap, gradual as the player moves); managers + ship captains are the galaxy-wide
         Lua census (SyncNpcCensus). Faction id via $st.owner.id (faction datatype `id`) so it MATCHES the Lua
         census ("argon", not the display knownname). knownname-gated (named officers only). Reuses the existing
         AIChat.index_npcs -> /v1/npcs/index path; role rides as a 3rd '~' field. -->
    <library name="Census_officers" purpose="run_actions">
      <actions>
        <set_value name="$sid" exact="'game_unset'"/>
        <do_if value="md.ai_influence_chat.Save_identity.$save_uuid?">
          <set_value name="$sid" exact="'game_' + md.ai_influence_chat.Save_identity.$save_uuid"/>
        </do_if>
        <set_value name="$npcs" exact="''"/>
        <find_station groupname="$stations" space="player.sector" multiple="true"/>
        <do_for_each name="$st" in="$stations">
          <do_if value="$st.owner?">
            <set_value name="$fid" exact="$st.owner.id"/>
            <do_if value="$st.controlentity.{controlpost.defence}? and $st.controlentity.{controlpost.defence}.knownname?">
              <set_value name="$npcs" exact="$npcs + $st.controlentity.{controlpost.defence}.knownname + '~' + $fid + '~Defence Officer;'"/>
            </do_if>
            <do_if value="$st.controlentity.{controlpost.engineer}? and $st.controlentity.{controlpost.engineer}.knownname?">
              <set_value name="$npcs" exact="$npcs + $st.controlentity.{controlpost.engineer}.knownname + '~' + $fid + '~Engineer;'"/>
            </do_if>
          </do_if>
        </do_for_each>
        <debug_text text="'AIINF officers: stations=' + $stations.count + ' npcs=[' + $npcs + ']'" filter="general"/>
        <do_if value="$npcs != ''">
          <raise_lua_event name="'AIChat.index_npcs'" param="'save_id=' + $sid + '|player=Player|npcs=' + $npcs"/>
        </do_if>
      </actions>
    </library>
    <cue name="Sync_on_load" instantiate="true" namespace="this">
      <conditions>
        <check_any>
                                                                                                                                                                                                                  <event_game_started/>
                                                                                                                                                                                                                  <event_game_loaded/>
                                                                                                                                                                                                                </check_any>
      </conditions>
      <actions>
        <run_actions ref="md.ai_influence_worldsync.Do_sync"/>
        <run_actions ref="md.ai_influence_worldsync.Census_officers"/>
        <!-- Census_npcs (old MD station-manager attempt) stays DORMANT: managers come from the Lua SyncNpcCensus
             (GetComponentData tradenpc). Census_officers reads the NON-default posts (defence/engineer) MD-only. -->
      </actions>
    </cue>
    <cue name="Sync_periodic" namespace="this">
      <actions>
        <set_value name="$started" exact="1"/>
      </actions>
      <cues>
        <cue name="Tick" namespace="this">
          <delay exact="15s" />
          <actions>
            <run_actions ref="md.ai_influence_worldsync.Do_sync"/>
            <run_actions ref="md.ai_influence_worldsync.Census_officers"/>
            <reset_cue cue="Tick"/>
          </actions>
        </cue>
      </cues>
    </cue>
  </cues>
</mdscript>